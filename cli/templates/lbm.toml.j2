[lbm]
version = 1
ready_label = "ready-for-dev"
{% if guidance_file %}
guidance_file = "{{ guidance_file }}"
{% endif %}

[build]
runtime = "{{ runtime }}"
install = "{{ install_cmd }}"
{% if lint_cmd %}
lint = "{{ lint_cmd }}"
{% endif %}
{% if typecheck_cmd %}
typecheck = "{{ typecheck_cmd }}"
{% endif %}
{% if build_cmd %}
build = "{{ build_cmd }}"
{% endif %}

[checks]
required = {{ required_checks }}
repair_from = {{ required_checks }}
max_repair_attempts = 10
max_ralph_loops = 0

# PR comments containing any of these substrings trigger a repair, with the
# comment body as failure context. Empty list disables the feature.
repair_comment_triggers = ["<!-- lbm-repair -->"]

# A PR comment containing this marker becomes the agent's Preview link in the
# status table (the report is the preview). Empty disables the feature.
preview_comment_marker = "<!-- lbm-preview -->"

[plan]
# Opt-in two-phase iterations: agents first propose a plan, a winner is merged
# to lbm-plans/issue-<N>/plan.md via `/merge-plan <alias> [feedback]`, then agents
# implement against it and the normal `/merge` flow picks the winning code PR.
# Default off = today's single-phase flow.
enabled = false
# dir = "lbm-plans"      # where plans are committed
# feedback_revs = 1      # max plan feedback revisions before finalize
# prototype = false      # allow a prototype PR (auto-run -> report) before planning
# A prototype-PR report carrying this marker re-invokes the agent to write its
# plan using the report as context (requires prototype = true).
# plan_context_comment_marker = "<!-- lbm-plan-context -->"

[deploy]
platform = "{{ deploy_platform }}"
{% if deploy_platform != "none" %}
preview_env = "Preview"
{% endif %}
{% if deploy_platform in ["fly", "railway"] %}
app_prefix = "{{ app_prefix }}"
region = "{{ deploy_region }}"
registry = "ghcr"
{% endif %}

[llm]
provider = "{{ llm_provider }}"
summary_model = "{{ summary_model }}"

{% for harness_name, harness in harnesses.items() %}
[harnesses.{{ harness_name }}]
mention = "{{ harness.mention }}"

{% endfor %}
{% for agent in agents %}
[[agents]]
harness = "{{ agent.harness }}"
model_id = "{{ agent.model_id }}"
model_label = "{{ agent.model_label }}"
{% endfor %}
