name: "LBM: Comment Commands"
on:
  issue_comment:
    types: [created]
  pull_request_review_comment:
    types: [created]
permissions:
  contents: write
  issues: write
  pull-requests: write
  id-token: write
jobs:
  handle:
    uses: {{ lbm_repo }}/.github/workflows/_comments.yml@{{ lbm_ref }}
    secrets:
      LBM_APP_ID: ${{ '{{' }} secrets.LBM_APP_ID {{ '}}' }}
      LBM_APP_PRIVATE_KEY: ${{ '{{' }} secrets.LBM_APP_PRIVATE_KEY {{ '}}' }}
      PAT_TOKEN: ${{ '{{' }} secrets.PAT_TOKEN {{ '}}' }}
      ANTHROPIC_API_KEY: ${{ '{{' }} secrets.ANTHROPIC_API_KEY {{ '}}' }}
      OPENAI_API_KEY: ${{ '{{' }} secrets.OPENAI_API_KEY {{ '}}' }}
      GEMINI_API_KEY: ${{ '{{' }} secrets.GEMINI_API_KEY {{ '}}' }}
    with:
      config-path: lbm.toml
{% if 'claude' in harnesses %}
  claude:
    if: >-
      github.event_name == 'issue_comment' &&
      contains(github.event.comment.body, '@claude')
    uses: {{ lbm_repo }}/.github/workflows/_agent-claude.yml@{{ lbm_ref }}
    secrets:
      LBM_APP_ID: ${{ '{{' }} secrets.LBM_APP_ID {{ '}}' }}
      LBM_APP_PRIVATE_KEY: ${{ '{{' }} secrets.LBM_APP_PRIVATE_KEY {{ '}}' }}
      PAT_TOKEN: ${{ '{{' }} secrets.PAT_TOKEN {{ '}}' }}
      ANTHROPIC_API_KEY: ${{ '{{' }} secrets.ANTHROPIC_API_KEY {{ '}}' }}
      OPENAI_API_KEY: ${{ '{{' }} secrets.OPENAI_API_KEY {{ '}}' }}
      GEMINI_API_KEY: ${{ '{{' }} secrets.GEMINI_API_KEY {{ '}}' }}
    with:
      config-path: lbm.toml
{% endif %}
