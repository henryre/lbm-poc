name: "LBM: Comment Commands"
on:
  issue_comment:
    types: [created]
  pull_request_review_comment:
    types: [created]
permissions:
  contents: write
  issues: write
  pull-requests: write
  id-token: write
jobs:
  handle:
    uses: {{ lbm_repo }}/.github/workflows/_comments.yml@{{ lbm_ref }}
    secrets: inherit
    with:
      config-path: lbm.toml
{% if 'claude' in harnesses %}
  claude:
    if: >-
      github.event_name == 'issue_comment' &&
      contains(github.event.comment.body, '@claude')
    uses: {{ lbm_repo }}/.github/workflows/_agent-claude.yml@{{ lbm_ref }}
    secrets: inherit
    with:
      config-path: lbm.toml
{% endif %}
