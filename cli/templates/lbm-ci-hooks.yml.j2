name: "LBM: CI Hooks"
on:
  workflow_run:
    workflows: {{ required_checks }}
    types: [completed]
  deployment_status:
permissions:
  contents: read
  issues: write
  pull-requests: write
  actions: read
jobs:
  hooks:
    uses: {{ lbm_repo }}/.github/workflows/_ci-hooks.yml@{{ lbm_ref }}
    secrets:
      LBM_APP_ID: ${{ '{{' }} secrets.LBM_APP_ID {{ '}}' }}
      LBM_APP_PRIVATE_KEY: ${{ '{{' }} secrets.LBM_APP_PRIVATE_KEY {{ '}}' }}
      PAT_TOKEN: ${{ '{{' }} secrets.PAT_TOKEN {{ '}}' }}
      ANTHROPIC_API_KEY: ${{ '{{' }} secrets.ANTHROPIC_API_KEY {{ '}}' }}
      OPENAI_API_KEY: ${{ '{{' }} secrets.OPENAI_API_KEY {{ '}}' }}
      GEMINI_API_KEY: ${{ '{{' }} secrets.GEMINI_API_KEY {{ '}}' }}
    with:
      config-path: lbm.toml
